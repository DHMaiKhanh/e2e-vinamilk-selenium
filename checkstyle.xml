<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Baseline style gate for the Vinamilk automation framework.
    Kept intentionally small: naming, imports and basic formatting only.
    Wired as violationSeverity=warning (non-blocking) in the parent pom;
    tighten to "error" once the team has burned down the backlog.
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>

    <module name="TreeWalker">
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
        <module name="EmptyBlock">
            <property name="option" value="text"/>
        </module>
        <module name="NeedBraces"/>
        <module name="EqualsHashCode"/>
        <module name="SimplifyBooleanExpression"/>
        <module name="PackageName">
            <property name="format" value="^com\.vinamilk\.automation(\.[a-z][a-zA-Z0-9]*)*$"/>
        </module>
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>
    </module>

    <!-- Not tree-based, so it must live directly under Checker rather than TreeWalker. -->
    <module name="LineLength">
        <property name="max" value="130"/>
        <property name="ignorePattern" value="^import .*|^\s*\*.*"/>
    </module>
</module>
